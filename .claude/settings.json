{
    "permissions": {
        "allow": [
            "mcp__plugin_context7_context7"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./credentials.json)",
            "Read(./**/Build/**)",
            "Write(./**/Build/**)",
            "Bash(curl *)"
        ]
    },
    "hooks": {
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "sh .claude/hooks/unity-validate.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/open-viewer.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Task|Agent",
                "hooks": [
                    {
                        "type": "command",
                        "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-router.sh\""
                    }
                ]
            }
        ]
    }
}
